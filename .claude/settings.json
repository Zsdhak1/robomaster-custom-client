{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-lint.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "先判断本回合是否有代码改动（写入/编辑过文件）。\n\n若为只读分析、审计、问答等零改动任务：无需任何检查，直接结束，不要输出 [APPROVED]。\n\n若本回合确有代码改动，则对改动文件执行最终质量检查：\n1. 运行 flutter analyze，确认未引入新的 warning/error\n2. 检查改动文件的函数长度是否合规\n3. 确认未破坏现有功能\n4. 若有相关测试，运行并确认通过\n全部通过则输出 [APPROVED]；否则列出待修复项并继续工作。",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissionMode": "ask",
  "include": ["AGENTS.md", "feature_spec.md"]
}
