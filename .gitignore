#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android signing secrets
/android/key.properties
/android/app/*.keystore
/android/app/*.jks

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Python generated protobuf bindings (regenerated locally by protoc)
*_pb2.py
*_pb2_grpc.py

# --- Project-specific exclusions (not for version control) ---
# Large reference PDFs (protocol / rules manuals) — keep out of git
*.pdf
# Temporary text extracted from PDFs during analysis
_*.txt
# Local validation screenshots
validationscreenshot/
test_data/
新建 文本文档.txt

# Local Git worktrees
/.worktrees/
